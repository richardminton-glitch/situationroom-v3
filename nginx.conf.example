# Situation Room V3 — nginx config
#
# Post-cutover topology (2026-04-15+):
#   situationroom.space        → v3 (Next.js, port 3001)
#   v3.situationroom.space     → v3 (alias, retained until ~2026-07-15)
#   legacy.situationroom.space → v2 (Express,  port 3000)
#
# Place this file in /etc/nginx/sites-available/situationroom-v3 and symlink
# into sites-enabled. SSL certs via:
#   certbot --nginx -d situationroom.space -d www.situationroom.space \
#                   -d v3.situationroom.space -d legacy.situationroom.space

# ── Apex: situationroom.space (v3) ──────────────────────────────────────
server {
    listen 80;
    server_name situationroom.space www.situationroom.space v3.situationroom.space;
    return 301 https://situationroom.space$request_uri;
}

# www → apex redirect (HTTPS)
server {
    listen 443 ssl;
    server_name www.situationroom.space;

    ssl_certificate     /etc/letsencrypt/live/situationroom.space/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/situationroom.space/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    return 301 https://situationroom.space$request_uri;
}

# Main v3 server — apex + v3 alias
server {
    listen 443 ssl;
    server_name situationroom.space v3.situationroom.space;

    ssl_certificate     /etc/letsencrypt/live/situationroom.space/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/situationroom.space/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    # Security headers (carried over from v2's nginx config)
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
    add_header X-Content-Type-Options    "nosniff" always;
    add_header X-Frame-Options           "SAMEORIGIN" always;
    add_header Referrer-Policy           "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy        "camera=(), microphone=(), geolocation=(), payment=()" always;

    server_tokens off;

    # Rate limit /api/
    limit_req_zone $binary_remote_addr zone=api:10m rate=30r/m;

    # Umami carve-outs — must come BEFORE the catch-all `location /` so
    # they take precedence. Umami runs on port 3002 and serves the metrics
    # script + collection endpoint under v3's domain (ad-blocker bypass).
    location = /metrics.js {
        proxy_pass http://127.0.0.1:3002/metrics.js;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
    location = /api/collect {
        proxy_pass http://127.0.0.1:3002/api/collect;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Next.js static assets — long cache, immutable
    location /_next/static/ {
        proxy_pass http://127.0.0.1:3001;
        add_header Cache-Control "public, max-age=604800, immutable";
    }

    # Rate-limited /api/
    location /api/ {
        limit_req zone=api burst=10 nodelay;
        proxy_pass         http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_hide_header  X-Powered-By;
    }

    # Catch-all → v3 Next.js
    location / {
        proxy_pass         http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        'upgrade';
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        proxy_hide_header  X-Powered-By;
    }

    # Block common attack paths
    location ~* /(\.env|\.git|wp-admin|wp-login|phpmyadmin|xmlrpc) {
        return 444;
    }

    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml;
}

# ── Legacy: legacy.situationroom.space (v2) ─────────────────────────────
server {
    listen 80;
    server_name legacy.situationroom.space;
    return 301 https://legacy.situationroom.space$request_uri;
}

server {
    listen 443 ssl;
    server_name legacy.situationroom.space;

    ssl_certificate     /etc/letsencrypt/live/legacy.situationroom.space/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/legacy.situationroom.space/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
    add_header X-Content-Type-Options    "nosniff" always;
    add_header X-Frame-Options           "SAMEORIGIN" always;
    server_tokens off;

    location / {
        proxy_pass         http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        'upgrade';
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_hide_header  X-Powered-By;
    }
}
