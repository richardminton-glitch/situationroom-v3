# Database
DATABASE_URL="postgresql://user:password@localhost:5432/situationroom_v3"

# Auth
SESSION_SECRET="generate-a-random-string-here"

# Email (choose one)
# RESEND_API_KEY=""
# POSTMARK_API_KEY=""

# Grok (xAI) — used for daily briefing generation
GROK_API_KEY=""

# Cron secret — protects briefing generation endpoint
CRON_SECRET="generate-a-random-string-here"

# API-Ninjas
API_NINJAS_KEY=""

# FRED (Federal Reserve Economic Data) — central bank rates chart, balance sheets
FRED_API_KEY=""

# Pool Lightning address (shown on pool donate splash)
NEXT_PUBLIC_POOL_LN_ADDRESS=""
NEXT_PUBLIC_POOL_LNURL=""

# Ops Lightning address (subscriptions + donations)
NEXT_PUBLIC_OPS_LN_ADDRESS=""
NEXT_PUBLIC_OPS_LNURL=""

# LNMarkets — Ops account (subscriptions + donations)
LNM_OPS_KEY=""
LNM_OPS_SECRET=""
LNM_OPS_PASSPHRASE=""

# LNMarkets — Bot account (trading pool)
LNM_BOT_KEY=""
LNM_BOT_SECRET=""
LNM_BOT_PASSPHRASE=""

# Port — use 3001 in production to coexist with V2 on port 3000
PORT=3001

# Node environment
NODE_ENV="development"
