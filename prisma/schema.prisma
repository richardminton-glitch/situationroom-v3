generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  displayName  String?  @map("display_name")
  timezone     String   @default("Europe/London")
  currencyPref String   @default("USD") @map("currency_pref")
  themePref    String   @default("parchment") @map("theme_pref")
  pin          String?                        // static 4-digit login PIN
  tier         String   @default("free")
  isPublic     Boolean  @default(false) @map("is_public")
  createdAt    DateTime @default(now()) @map("created_at")
  lastSeenAt   DateTime @default(now()) @map("last_seen_at")

  // ── Nostr identity ──────────────────────────────────────────────────────────
  nostrNpub         String?  @unique @map("nostr_npub")
  nostrAuthType     String   @default("email") @map("nostr_auth_type")
  // 'email' = email/PIN only, 'assigned' = server keypair, 'native' = user's own key, 'upgraded' = was assigned, now native
  assignedNpub      String?  @unique @map("assigned_npub")
  assignedPrivkeyEnc String? @map("assigned_privkey_enc")  // AES-256-GCM encrypted hex
  chatDisplayName   String   @default("") @map("chat_display_name")
  chatIcon          String   @default("email") @map("chat_icon")  // 'lightning' | 'email' | 'bot'

  // ── Subscription ────────────────────────────────────────────────────────────
  subscriptionExpiresAt   DateTime? @map("subscription_expires_at")
  subscriptionActivatedAt DateTime? @map("subscription_activated_at")

  // ── Newsletter ───────────────────────────────────────────────────────────────
  newsletterEnabled   Boolean   @default(true)  @map("newsletter_enabled")
  newsletterFrequency String    @default("weekly") @map("newsletter_frequency")  // 'daily' | 'weekly'
  newsletterDay       Int       @default(0) @map("newsletter_day")  // 0=Sunday … 6=Saturday
  newsletterVipTopics String[]  @map("newsletter_vip_topics")
  newsletterLastSent  DateTime? @map("newsletter_last_sent")
  newsletterConfirmedAt DateTime? @map("newsletter_confirmed_at")

  // ── Lifecycle emails ────────────────────────────────────────────────────────
  welcomeEmailSentAt   DateTime? @map("welcome_email_sent_at")
  // Set when the 3-day expiry warning has been sent for the *current* subscription.
  // Reset to null inside activateTier so renewals get a fresh warning next cycle.
  expiryWarningSentAt  DateTime? @map("expiry_warning_sent_at")

  // ── Migration provenance ────────────────────────────────────────────────────
  // Tracks where a user record came from. null = organic v3 signup.
  // Set to "v2-migration-general" or "v2-migration-members" when imported by
  // /api/admin/import-v2 during the v2→v3 cutover (April 2026). Used for
  // audit, reversal, and to scope the migration broadcast to imported users.
  source                    String?   @map("source")
  // Set after the migration announcement email has been sent to this user.
  // Idempotent guard for /api/admin/broadcast-migration so re-runs skip
  // already-sent users unless force=true.
  migrationBroadcastSentAt  DateTime? @map("migration_broadcast_sent_at")

  // ── Bot Room / TradingView ──────────────────────────────────────────────────
  tvChartState Json? @map("tv_chart_state")  // TradingView saved chart state (indicators, drawings, interval, etc.)

  sessions    Session[]
  pinCodes    PinCode[]
  layouts     UserLayout[]
  watchlists  UserWatchlist[]
  bookmarks   UserBookmark[]
  preferences UserPreference[]
  payments    SubscriptionPayment[]

  @@map("users")
}

model NostrChallenge {
  id        String    @id @default(cuid())
  challenge String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")

  @@index([expiresAt])
  @@map("nostr_challenges")
}

model Session {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  token        String   @unique
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model PinCode {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  pin       String
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("pin_codes")
}

model UserLayout {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  layoutJson String   @map("layout_json") @db.Text
  isDefault  Boolean  @default(false) @map("is_default")
  name       String   @default("Default")
  theme      String   @default("parchment")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_layouts")
}

model UserWatchlist {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  itemsJson String   @map("items_json") @db.Text
  isPublic  Boolean  @default(false) @map("is_public")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_watchlists")
}

model UserBookmark {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  briefingDate DateTime @map("briefing_date") @db.Date
  note         String?
  isPublic     Boolean  @default(false) @map("is_public")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_bookmarks")
}

model UserPreference {
  id     String @id @default(cuid())
  userId String @map("user_id")
  key    String
  value  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@map("user_preferences")
}

model Briefing {
  id                  String   @id @default(cuid())
  date                DateTime @unique @db.Date
  generatedAt         DateTime @map("generated_at")
  marketSection       String   @map("market_section") @db.Text
  networkSection      String   @map("network_section") @db.Text
  geopoliticalSection String   @map("geopolitical_section") @db.Text
  macroSection        String   @map("macro_section") @db.Text
  outlookSection      String   @map("outlook_section") @db.Text
  dataSnapshotJson    String   @map("data_snapshot_json") @db.Text
  sourcesJson         String   @map("sources_json") @db.Text
  headlinesJson       String   @default("[]") @map("headlines_json") @db.Text
  threatLevel         String   @map("threat_level")
  threatScore         Int      @default(0) @map("threat_score")
  convictionScore     Float    @map("conviction_score")
  headline            String

  @@map("briefings")
}

model ConvictionScore {
  id                          String   @id @default(cuid())
  date                        DateTime @unique @db.Date
  compositeScore              Float    @map("composite_score")
  priceMomentumScore          Float    @map("price_momentum_score")
  priceMomentumDataJson       String   @map("price_momentum_data_json") @db.Text
  onchainHealthScore          Float    @map("onchain_health_score")
  onchainHealthDataJson       String   @map("onchain_health_data_json") @db.Text
  macroEnvironmentScore       Float    @map("macro_environment_score")
  macroEnvironmentDataJson    String   @map("macro_environment_data_json") @db.Text
  networkFundamentalsScore    Float    @map("network_fundamentals_score")
  networkFundamentalsDataJson String   @map("network_fundamentals_data_json") @db.Text
  sentimentScore              Float    @map("sentiment_score")
  sentimentDataJson           String   @map("sentiment_data_json") @db.Text

  @@map("conviction_scores")
}

model DataSnapshot {
  id        String   @id @default(cuid())
  timestamp DateTime @default(now())
  dataJson  String   @map("data_json") @db.Text

  @@map("data_snapshots")
}

model DataCache {
  id        String   @id @default(cuid())
  key       String   @unique
  data      String   @db.Text
  expiresAt DateTime @map("expires_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@map("data_cache")
}

// ── Daily Snapshot Tables (recorded at midnight UTC) ──

model DailyBtc {
  date         DateTime @id @db.Date
  price        Float
  marketCap    Float    @map("market_cap")
  volume24h    Float    @map("volume_24h")
  change24h    Float    @map("change_24h")
  change7d     Float    @map("change_7d")
  change30d    Float    @map("change_30d")
  ath          Float
  athChangePct Float    @map("ath_change_pct")
  supply       Float

  @@map("daily_btc")
}

model DailyNetwork {
  date        DateTime @id @db.Date
  hashrateEh  Float    @map("hashrate_eh")
  difficulty  Float
  feeFast     Float    @map("fee_fast")
  feeMedium   Float    @map("fee_medium")
  mempoolMb   Float    @map("mempool_mb")
  blockHeight Int      @map("block_height")

  @@map("daily_network")
}

model DailyLightning {
  date        DateTime @id @db.Date
  channels    Int
  capacityBtc Float    @map("capacity_btc")
  nodes       Int

  @@map("daily_lightning")
}

model DailyOnchain {
  date            DateTime @id @db.Date
  mvrv            Float
  exchangeInflow  Float    @map("exchange_inflow")
  exchangeOutflow Float    @map("exchange_outflow")
  exchangeBalance Float    @map("exchange_balance")

  @@map("daily_onchain")
}

model DailyIndices {
  date    DateTime @id @db.Date
  sp500   Float?
  nasdaq  Float?
  dow     Float?
  ftse    Float?
  dax     Float?
  nikkei  Float?
  hangSeng Float?  @map("hang_seng")
  vix     Float?
  dxy     Float?
  us10y   Float?
  us2y    Float?

  @@map("daily_indices")
}

model DailyCommodities {
  date       DateTime @id @db.Date
  gold       Float?
  silver     Float?
  crudeOil   Float?   @map("crude_oil")
  naturalGas Float?   @map("natural_gas")
  copper     Float?

  @@map("daily_commodities")
}

model DailyFx {
  date   DateTime @id @db.Date
  eurUsd Float?   @map("eur_usd")
  gbpUsd Float?   @map("gbp_usd")
  usdJpy Float?   @map("usd_jpy")
  usdCny Float?   @map("usd_cny")

  @@map("daily_fx")
}

model DailySentiment {
  date            DateTime @id @db.Date
  fearGreed       Int?     @map("fear_greed")
  convictionScore Float?   @map("conviction_score")
  threatLevel     String?  @map("threat_level")

  @@map("daily_sentiment")
}

model BtcPriceHistory {
  date  DateTime @id @db.Date
  close Float

  @@map("btc_price_history")
}

// ── Payments & Subscriptions ──────────────────────────────────────────────────

model SubscriptionPayment {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  tier         String    // 'general' | 'members' | 'vip' | 'donation'
  amountSats   Int       @map("amount_sats")
  memo         String
  lnmDepositId String?   @unique @map("lnm_deposit_id")
  paymentRequest String? @map("payment_request") @db.Text
  status       String    @default("pending")  // 'pending' | 'confirmed' | 'expired'
  activatedAt  DateTime? @map("activated_at")
  expiresAt    DateTime? @map("expires_at")   // subscription end date (not invoice expiry)
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([lnmDepositId])
  @@map("subscription_payments")
}

model UpgradeAttempt {
  id              String    @id @default(cuid())
  userId          String?   @map("user_id")
  triggerFeature  String    @map("trigger_feature")
  requiredTier    String    @map("required_tier")
  userTier        String    @map("user_tier")
  converted       Boolean   @default(false)
  convertedAt     DateTime? @map("converted_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([triggerFeature])
  @@map("upgrade_attempts")
}

// ── Nostr Relay Whitelist ─────────────────────────────────────────────────────
// Tracks which npubs are currently authorised to post on the private relay.
// Managed automatically on tier activation / expiry.

model NostrRelayWhitelist {
  id        String   @id @default(cuid())
  npub      String   @unique
  userId    String   @map("user_id")
  addedAt   DateTime @default(now()) @map("added_at")
  removedAt DateTime? @map("removed_at")  // null = currently active
  active    Boolean  @default(true)

  @@index([npub])
  @@index([userId])
  @@index([active])
  @@map("nostr_relay_whitelist")
}

// ── Chat Messages ─────────────────────────────────────────────────────────────
// Stores all Ops Room chat messages (human + bot).
// nostrEventId: if message was also posted to the Nostr relay, its event ID.

model ChatMessage {
  id              String   @id @default(cuid())
  roomId          String   @default("ops") @map("room_id")
  authorNpub      String   @map("author_npub")
  authorDisplay   String   @map("author_display")
  authorIcon      String   @default("email") @map("author_icon")  // 'lightning' | 'email' | 'bot'
  content         String   @db.Text
  nostrEventId    String?  @unique @map("nostr_event_id")
  isBot           Boolean  @default(false) @map("is_bot")
  eventType       String?  @map("event_type")  // null for human, 'alert' | 'briefing' | 'whale' etc for bot
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([roomId, createdAt])
  @@index([authorNpub])
  @@map("chat_messages")
}

// ── Chat Alert Log ────────────────────────────────────────────────────────────
// Prevents duplicate auto-post firing for the same event within 24hr.

model ChatAlertLog {
  id          String   @id @default(cuid())
  eventType   String   @map("event_type")  // e.g. 'btc_move_up_3pct'
  eventKey    String   @map("event_key")   // dedup key, e.g. 'btc_67000_up'
  firedAt     DateTime @default(now()) @map("fired_at")

  @@unique([eventType, eventKey])
  @@index([firedAt])
  @@map("chat_alert_log")
}

// ── Newsletter Sends Log ──────────────────────────────────────────────────────

model NewsletterSend {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  briefingDate DateTime  @map("briefing_date") @db.Date
  tier         String    // 'free' | 'general' | 'members' | 'vip'
  status       String    @default("sent")  // 'sent' | 'failed' | 'skipped'
  error        String?
  sentAt       DateTime  @default(now()) @map("sent_at")

  @@index([userId])
  @@index([briefingDate])
  @@map("newsletter_sends")
}

// ── V2 → V3 Migration Audit Logs ──────────────────────────────────────────────
// One-off audit tables created for the April 2026 cutover from v2
// (situationroom.space) to v3. One row per import run; one row per
// announcement email send. Useful for reversal queries and post-mortems.

model MigrationImport {
  id             String   @id @default(cuid())
  runAt          DateTime @default(now()) @map("run_at")
  actorEmail     String   @map("actor_email")        // admin who ran it (or "cron")
  rowCount       Int      @map("row_count")
  insertedCount  Int      @map("inserted_count")
  updatedCount   Int      @map("updated_count")
  skippedCount   Int      @map("skipped_count")
  errorCount     Int      @default(0) @map("error_count")
  notes          String?  @db.Text                   // optional free-text summary

  @@index([runAt])
  @@map("migration_imports")
}

model MigrationBroadcast {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  email     String                                    // captured at send-time in case the user is later deleted
  tier      String                                    // 'general' | 'members' (the tier they were grandfathered to)
  status    String   @default("sent")                 // 'sent' | 'failed' | 'skipped'
  error     String?
  sentAt    DateTime @default(now()) @map("sent_at")

  @@index([userId])
  @@index([sentAt])
  @@map("migration_broadcasts")
}

// ── VIP Tier Models ───────────────────────────────────────────────────────────

model UserAlert {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  triggerType String    @map("trigger_type")  // 'conviction' | 'lth_supply' | 'hash_ribbon' | 'btc_price' | 'fear_greed' | 'new_briefing'
  condition   String    // 'above' | 'below' | 'flip' | 'any'
  threshold   Float?    // value to compare against (null for 'flip'/'any' triggers)
  label       String    @default("")  // user-readable description
  isActive    Boolean   @default(true) @map("is_active")
  lastFiredAt DateTime? @map("last_fired_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([isActive])
  @@map("user_alerts")
}

model VipBriefing {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  topicHash    String   @map("topic_hash")
  date         DateTime @db.Date
  topics       String   @default("[]") @db.Text   // JSON array of topic keys
  contentJson  String   @map("content_json") @db.Text  // {market, network, geo, macro, outlook}
  headline     String
  generatedAt  DateTime @default(now()) @map("generated_at")

  @@unique([userId, date])
  @@index([topicHash, date])
  @@map("vip_briefings")
}

model SignalAnnotation {
  id          String   @id @default(cuid())
  panelId     String   @map("panel_id")
  valueKey    String   @map("value_key")   // rounded metric + value as dedup key
  annotation  String   @db.Text            // AI-generated annotation text
  generatedAt DateTime @default(now()) @map("generated_at")
  expiresAt   DateTime @map("expires_at")  // typically data refresh + 24hr

  @@unique([panelId, valueKey])
  @@index([expiresAt])
  @@map("signal_annotations")
}

// ── RSS Classification Cache ──────────────────────────────────────────────────
// Stores article classification results keyed by sha256(title|feedUrl).
// TTL = 7 days. Populated by the classifier pipeline; cleaned up by daily cron.
// Run: npx prisma migrate dev --name add_classification_cache

// ── Trading Bot ──────────────────────────────────────────────────────────────
// AI trading decisions and executed trades (LN Markets integration).

model TradingDecision {
  id              String    @id @default(cuid())
  snapshotJson    String    @map("snapshot_json") @db.Text
  aiResponseRaw   String    @map("ai_response_raw") @db.Text
  decision        String    // OPEN_LONG | OPEN_SHORT | CLOSE | HOLD | FLAT | ADJUST
  conviction      Int
  reasoningJson   String    @map("reasoning_json") @db.Text
  tradeJson       String?   @map("trade_json") @db.Text
  guardrailPass   Boolean   @map("guardrail_pass")
  guardrailReason String?   @map("guardrail_reason")
  approvalStatus  String    @default("pending") @map("approval_status") // pending | approved | rejected | blocked
  approvedAt      DateTime? @map("approved_at")
  executed        Boolean   @default(false)
  executionJson   String?   @map("execution_json") @db.Text
  chatMessage     String?   @map("chat_message") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")

  trade           Trade?

  @@index([createdAt])
  @@map("trading_decisions")
}

model Trade {
  id          String    @id @default(cuid())
  decisionId  String    @unique @map("decision_id")
  lnmTradeId  String?   @map("lnm_trade_id")
  side        String    // 'long' | 'short'
  entryPrice  Float     @map("entry_price")
  exitPrice   Float?    @map("exit_price")
  marginSats  Int       @map("margin_sats")
  leverage    Float
  takeProfit  Float?    @map("take_profit")
  stopLoss    Float?    @map("stop_loss")
  pnlSats     Int?      @map("pnl_sats")
  pnlPct      Float?    @map("pnl_pct")
  status      String    @default("running") // 'running' | 'closed'
  closeReason String?   @map("close_reason") // 'tp_hit' | 'sl_hit' | 'manual' | 'ai_decision' | 'liquidation'
  openedAt    DateTime  @default(now()) @map("opened_at")
  closedAt    DateTime? @map("closed_at")

  decision    TradingDecision @relation(fields: [decisionId], references: [id])

  @@index([status])
  @@index([lnmTradeId])
  @@map("trades")
}

// ── RSS Classification Cache ──────────────────────────────────────────────────

model ClassificationCache {
  contentHash         String   @id @map("content_hash")
  primaryCategory     String   @map("primary_category")
  secondaryCategories String[] @map("secondary_categories")
  confidence          Float
  relevanceToBitcoin  Int      @map("relevance_to_bitcoin")
  method              String
  reasoning           String?
  createdAt           DateTime @default(now()) @map("created_at")
  expiresAt           DateTime @map("expires_at")

  @@index([expiresAt])
  @@map("classification_cache")
}

// ── Country Data (Global Situation Map) ──────────────────────────────────────

model CountryData {
  id            String   @id @default(cuid())
  countryCode   String   @unique @map("country_code")    // ISO 3166-1 alpha-2 ("US", "DE")
  countryName   String   @map("country_name")
  isoNumeric    Int      @unique @map("iso_numeric")     // matches TopoJSON feature IDs

  // Static — seeded once
  capital       String?
  region        String?
  areaKm2       Int?     @map("area_km2")
  currency      String?
  language      String?
  debtPct       Float?   @map("debt_pct")
  freedomScore  Float?   @map("freedom_score")
  giniIndex     Float?   @map("gini_index")
  hdi           Float?
  lifeExp       Float?   @map("life_exp")
  homicideRate  Float?   @map("homicide_rate")
  corruption    Int?
  peaceRank     Int?     @map("peace_rank")
  pressRank     Int?     @map("press_rank")
  democracy     Float?
  co2PerCap     Float?   @map("co2_per_cap")
  forestPct     Float?   @map("forest_pct")
  medianAge     Float?   @map("median_age")
  trivia        String?

  // Live — updated monthly via cron
  population    BigInt?
  gdpPerCap     Float?   @map("gdp_per_cap")
  gdpGrowth     Float?   @map("gdp_growth")
  unemployment  Float?
  inflation     Float?
  cbRate        Float?   @map("cb_rate")
  urbanPct      Float?   @map("urban_pct")
  fertility     Float?
  infantMort    Float?   @map("infant_mort")
  aqi           Int?
  aqiLabel      String?  @map("aqi_label")

  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("country_data")
}
